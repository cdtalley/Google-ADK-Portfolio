# Copy to .env in this folder (repo root). ADK loads this when agents start.

# Optional — if set to a **real** AI Studio key (not "YOUR_..._HERE"), agents use Gemini.
# Placeholder or short values are ignored → Ollama is used instead.
# GOOGLE_API_KEY=

# Optional — LiteLLM talks to Ollama here (default avoids Windows localhost IPv6 issues).
# OLLAMA_API_BASE=http://127.0.0.1:11434

# Optional — force any ADK-supported model id (overrides auto-selection).
# PORTFOLIO_ADK_MODEL=gemini-2.0-flash
# PORTFOLIO_ADK_MODEL=ollama/llama3.2:latest

# When using Ollama without PORTFOLIO_ADK_MODEL, you can change the default tag:
# PORTFOLIO_ADK_OLLAMA_MODEL=ollama/mistral
